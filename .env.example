# ============================================
# convergio-app — Environment Variables
# ============================================

# --- Public (exposed to browser) ---
# API URL for frontend requests (required)
NEXT_PUBLIC_API_URL=http://localhost:7777

# Application name displayed in the UI
NEXT_PUBLIC_APP_NAME=Convergio

# Auth token for client-side API calls (required)
NEXT_PUBLIC_AUTH_TOKEN=your-auth-token-here

# --- Server-side ---
# Path to Convergio configuration file
# CONVERGIO_CONFIG_PATH=/path/to/convergio.toml
