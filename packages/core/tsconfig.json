{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@/*": ["../../src/*"]
    },
    "baseUrl": "."
  },
  "include": ["*.ts", "../../src/**/*.ts", "../../src/**/*.tsx"],
  "exclude": ["node_modules"]
}
